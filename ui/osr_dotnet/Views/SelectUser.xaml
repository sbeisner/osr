<Page x:Class="osr_dotnet.Views.SelectUser"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:osr_dotnet.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SelectUser">

    <Grid>
        <Label Content="Select User" HorizontalAlignment="Left" Height="42" Margin="10,10,0,0" VerticalAlignment="Top" Width="266"/>
        <Button Content="Continue" HorizontalAlignment="Left" Height="29" Margin="34,255,0,0" VerticalAlignment="Top" Width="125" Click="Button_Click"/>
        <ComboBox Name="comboBox" HorizontalAlignment="Left" Height="21" Margin="34,78,0,0" VerticalAlignment="Top" Width="203" SelectionChanged="comboBox_SelectionChanged"/>

    </Grid>
</Page>
